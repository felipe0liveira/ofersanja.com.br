# Base runner image — node:20-alpine + Chromium system dependencies.
# Stored permanently in Artifact Registry. Only rebuild this when system
# dependencies change (rebuild with: make build-base).
FROM node:20-alpine

RUN apk add --no-cache chromium nss freetype harfbuzz ca-certificates ttf-freefont

ENV CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
